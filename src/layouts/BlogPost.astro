     ---
     export const prerender = true;
     const { title, pubDate, description } = Astro.props;
     ---
     <html>
       <head>
         <title>{title}</title>
       </head>
       <body>
         <article>
           <h1>{title}</h1>
           <p><small>{pubDate}</small></p>
           <p>{description}</p>
           <slot />
         </article>
       </body>
     </html>